# Copy to .env.local if you need overrides (optional).
# Absolute path to the julia-reader repo root (folder containing src/). Default: ../../ from this app.
# JULIA_READER_REPO_ROOT=

# Python interpreter (default: <repo>/.venv/bin/python3, else python3 on PATH).
# JULIA_READER_PYTHON=

# LLM settings are read by Python from the repo's .env (JULIA_READER_* / OPENAI_API_KEY) when offline mode is off.
