# ── Julia Reader Demo — Environment Variables ──────
# Copy this file to .env.local (or set in your shell) and fill in values.
# The Python backend reads these via dotenv; the Next.js server passes
# them through to the child process.
#
# You can also run  scripts/configure_model.py  from the repo root to
# generate the LLM block interactively.

# ── LLM Provider (OpenAI-compatible) ────────────────
# Bearer-style API key for the chat-completions endpoint.
# Falls back to OPENAI_API_KEY if unset.  (required unless offline)
JULIA_READER_API_KEY=

# Base URL for the provider API root.
# Must expose POST {base}/chat/completions in OpenAI shape.
# (optional, default: https://api.openai.com/v1)
JULIA_READER_BASE_URL=

# Model identifier to use for generation.
# (optional, default: gpt-4o-mini)
JULIA_READER_MODEL=

# Extra HTTP headers sent with every LLM request, as a JSON object string.
# Useful for providers that require non-standard auth (e.g. Azure).
# (optional)
# JULIA_READER_EXTRA_HEADERS={"api-key":"..."}

# Set to 1, true, yes, or on to skip ALL LLM calls and use local
# heuristic fallback only.  No API key is needed when this is enabled.
# (optional)
# JULIA_READER_DISABLE_LLM=1

# ── Demo App Overrides ──────────────────────────────
# Absolute path to the julia-reader repo root (the folder containing src/).
# The Next.js server uses this to locate the Python package.
# (optional, default: ../../  relative to this demo app)
# JULIA_READER_REPO_ROOT=

# Path to the Python interpreter used to run julia_reader.
# (optional, default: <repo>/.venv/bin/python3, then python3 on PATH)
# JULIA_READER_PYTHON=
