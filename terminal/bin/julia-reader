#!/usr/bin/env bash
# Direct entry to the installed console script (same flags as python -m julia_reader).
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TERMINAL_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
VENV="$TERMINAL_ROOT/.venv"
JR="$VENV/bin/julia-reader"

if [[ ! -x "$JR" ]]; then
  echo "julia-reader is not installed in $VENV" >&2
  echo "Run:  bash $TERMINAL_ROOT/setup.sh" >&2
  exit 1
fi

exec "$JR" "$@"
