# OpenAI-compatible API (default: OpenAI)
# Guided setup:  bash scripts/configure-model.sh
JULIA_READER_API_KEY=sk-...
JULIA_READER_BASE_URL=https://api.openai.com/v1
JULIA_READER_MODEL=gpt-4o-mini

# Optional: extra HTTP headers as JSON (e.g. Azure)
# JULIA_READER_EXTRA_HEADERS={"api-key":"..."}

# Skip all LLM calls (local heuristic fallback only)
# JULIA_READER_DISABLE_LLM=1
